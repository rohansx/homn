{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "homn-face",
  "version": "0.1.0",
  "identifier": "sh.homn.face",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
