# rust
/target
**/*.rs.bk
# Cargo.lock is COMMITTED — homn is a binary project, reproducible builds matter

# node (tauri webview / chrome extension)
node_modules
dist
.next
.cache

# tauri
src-tauri/target
src-tauri/Cargo.lock

# data / state (runtime only — never commit)
*.db
*.db-shm
*.db-wal
.local/

# logs
*.log
logs/

# editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# brainstorm artifacts from superpowers visual companion
.superpowers/

# ML model caches (accidentally created by tooling; not part of homn)
.fastembed_cache/
.cache/

# claude / spec-kit project state — agent folders can hold credentials
# per spec-kit's security warning; commit policy files explicitly, ignore the rest
.claude/settings.local.json
.claude/.credentials*

# spec-kit local workflow artifacts (commit specs + templates, ignore caches)
.specify/cache/

# secrets
.env
.env.*
!.env.example
